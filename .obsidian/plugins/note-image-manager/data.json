  "defaultFormat": "png",
  "defaultQuality": 80,
  "defaultLinkFormat": "markdown",
  "defaultPathFormat": "relative",
  "markdownPathEncodingStrategy": "encoded",
  "renamePattern": "{noteName}-{random}",
  "outputFolder": "./assets/${noteFileName}",
  "enablePasteHandler": true,
